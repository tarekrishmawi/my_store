{
  "name": "storefront-backend-api",
  "version": "1.0.1",
  "description": "Storefront API backend Project",
  "main": "server.ts",
  "scripts": {
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "db:up": "db-migrate up",
    "db:down": "db-migrate down",
    "migrate:test:up": "db-migrate up -e test",
    "migrate:test:down": "db-migrate reset -e test",
    "create:db": "tsx scripts/createDatabases.ts",
    "seed": "tsx scripts/seed.ts && tsx scripts/seedProducts.ts",
    "setup": "npm run create:db && npm run db:up && npm run seed",
    "setup:test": "npm run create:db && npm run migrate:test:up && npm run seed",
    "dev": "tsc-watch --onSuccess \"node dist/server.js\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "jasmine": "jasmine --config=spec/support/jasmine.json",
    "test": "docker exec storefront_backend_api sh -c \"npm run build && npm run migrate:test:up && npm run jasmine && npm run migrate:test:down\""
  },
  "keywords": [],
  "author": "Tarek Rishmawi",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.4.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "jasmine": "^6.1.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jasmine-ts": "^0.4.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.21.0"
  }
}